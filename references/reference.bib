	pages = {9691},
	file = {PDF:C\:\\Users\\ziada\\Zotero\\storage\\C7CQNC5K\\Altaibek et al. - 2025 - A Survey of Cross-Layer Security for Resource-Constrained IoT Devices.pdf:application/pdf},
